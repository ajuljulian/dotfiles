{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "git push": "ask",
      "git status": "allow",
      "git diff": "allow",
      "npm run build": "allow",
      "ls": "allow",
      "pwd": "allow"
    }
  },
  "mcp": {
      "excalidraw": {
        "type": "remote",
        "url": "https://api.excalidraw.com/api/v1/mcp",
        "enabled": true,
        "headers": {
          "Authorization": "Bearer {env:EXCALIDRAW_API_KEY}"
        }
      }
    },
  "model": "Kimi K2",
  "autoupdate": true
}
